{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/governor_hook.py"
          }
        ]
      }
    ]
  },

  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Read(~/.ssh/**)",
      "Read(**/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.aws/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Write(.claude/governor-settings.json)",
      "Edit(.claude/governor-settings.json)",
      "Write(scripts/governor_hook.py)",
      "Edit(scripts/governor_hook.py)",
      "Write(megalodon_ui/governor/**)",
      "Edit(megalodon_ui/governor/**)"
    ]
  }
}
